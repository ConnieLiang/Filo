  "generatedAt": "CI",
  "platformNaming": {
    "desktop": {
      "componentName": "{PascalCaseIcon}Icon",
      "fileName": "{icon-name}.tsx",
      "style": "React TSX component using currentColor"
    },
    "ios": {
      "imagesetName": "{icon-name}.imageset",
      "assetFileName": "{icon-name}.svg",
      "style": "Asset Catalog imageset with preserves-vector-representation"
    },
    "android": {
      "drawableName": "ic_{icon_name}.xml",
      "style": "VectorDrawable XML generated from SVG geometry"
    }
  },
  "syncTargets": {
    "desktop": {
      "repo": "FiloAI/filo-desktop",
      "base": "dev",
      "path": "generated/filo-design-icons/desktop"
    },
    "ios": {
      "repo": "FiloAI/filo-ios",
      "base": "main",
      "path": "generated/filo-design-icons/ios"
    },
    "android": {
      "repo": "FiloAI/filo-android",
      "base": "main",
      "path": "generated/filo-design-icons/android"
    }
  }
