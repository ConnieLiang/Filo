{
  "name": "Hugo",
  "target": "Filo Desktop",
  "version": "1.0.0",
  "purpose": "Soft Sepia Blue variant for Filo Desktop. Optimized for lower glare and a friendlier read.",
  "notes": [
    "Soft Sepia Blue was selected as the preferred direction.",
    "The personality sits in color1 to color5 plus color21 to color24. The neutral stack stays disciplined.",
    "This scheme is designed to remain calm even when color2 is reused aggressively across the Desktop UI."
  ],
  "semanticAliases": {
    "filoPrimary": "02-primary",
    "filoSecondary": "01-primary-light",
    "background": "10-background",
    "surface": "09-surface-tertiary",
    "textPrimary": "06-text-primary",
    "textSecondary": "07-text-secondary",
    "textTertiary": "08-text-tertiary",
    "error": "11-error",
    "warning": "12-important",
    "success": "18-success",
    "info": "13-info",
    "overlay": "14-overlay-light"
  },
  "tokenReplacements": {
    "color": {
      "01-primary-light": { "light": "#C7D5E4", "dark": "#97B0C8", "usage": "Primary accent, lighter variant" },
      "02-primary": { "light": "#6C87A1", "dark": "#85A0BA", "usage": "Primary brand color, active states, links" },
      "03-primary-dark": { "light": "#E3EBF3", "dark": "#273443", "usage": "Primary accent backgrounds" },
      "04-primary-darker": { "light": "#D8E3EE", "dark": "#334457", "usage": "Darker primary accent" },
      "05-surface-secondary": { "light": "#F5F4F0", "dark": "#302F31", "usage": "Secondary surface color" },
      "06-text-primary": { "light": "#1B1918", "dark": "#F6F3EE", "usage": "Primary text color" },
      "07-text-secondary": { "light": "#706A66", "dark": "#A29A95", "usage": "Secondary text, placeholders" },
      "08-text-tertiary": { "light": "#DDD6D1", "dark": "#514A47", "usage": "Tertiary text, disabled, standard divider color" },
      "09-surface-tertiary": { "light": "#FCFAF7", "dark": "#262424", "usage": "Tertiary surface" },
      "10-background": { "light": "#FEFCF8", "dark": "#1E1C1C", "usage": "Primary background" },
      "11-error": { "light": "#CF6A69", "dark": "#AF5757", "usage": "Error states, destructive actions" },
      "12-important": { "light": "#DEC07A", "dark": "#E7CC92", "usage": "Important states, caution" },
      "13-info": { "light": "#6A93B4", "dark": "#86A9C8", "usage": "Information, links" },
      "14-overlay-light": { "light": "rgba(27, 25, 24, 0.05)", "dark": "rgba(255, 255, 255, 0.08)", "usage": "Light overlays, selection backgrounds, subtle divider color" },
      "15-overlay-primary": { "light": "rgba(108, 135, 161, 0.12)", "dark": "rgba(133, 160, 186, 0.14)", "usage": "Primary color overlays" },
      "16-overlay-subtle": { "light": "rgba(199, 213, 228, 0.10)", "dark": "rgba(82, 90, 100, 0.10)", "usage": "Subtle overlays" },
      "17-success-light": { "light": "#E8F0E2", "dark": "#344033", "usage": "Success backgrounds" },
      "18-success": { "light": "#76955C", "dark": "#8CAB72", "usage": "Success states" },
      "19-warning": { "light": "#C88F42", "dark": "#D5A35A", "usage": "Warning states" },
      "20-error-light": { "light": "#F7E8E6", "dark": "#462D2C", "usage": "Error backgrounds" },
      "21-purple-light": { "light": "#E7E2F1", "dark": "#B8B0CC", "usage": "Purple accent light" },
      "22-purple": { "light": "#7C739E", "dark": "#968DB6", "usage": "Purple accent" },
      "23-pink-light": { "light": "#F3E0E3", "dark": "#D9BCC4", "usage": "Pink accent light" },
      "24-pink": { "light": "#B97A88", "dark": "#CB92A0", "usage": "Pink accent" },
      "25-neutral": { "light": "#BEB6B0", "dark": "#807873", "usage": "Neutral gray" }
    }
  }
}
