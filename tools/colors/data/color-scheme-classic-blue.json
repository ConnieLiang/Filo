{
  "name": "Classic Blue",
  "target": "Filo Desktop",
  "version": "2.1.0",
  "purpose": "Baseline Filo Desktop palette derived from the current shared design tokens.",
  "notes": [
    "This is the current production-oriented blue system from filo-design/tokens.json.",
    "The page uses this as the control scheme against newer variants like Ophelia.",
    "Appearance settings in Desktop currently only switch light, dark, and system. This scheme catalog is the scalable layer that does not exist yet in the app."
  ],
  "semanticAliases": {
    "filoPrimary": "02-primary",
    "filoSecondary": "01-primary-light",
    "background": "10-background",
    "surface": "09-surface-tertiary",
    "textPrimary": "06-text-primary",
    "textSecondary": "07-text-secondary",
    "textTertiary": "08-text-tertiary",
    "error": "11-error",
    "warning": "12-important",
    "success": "18-success",
    "info": "13-info",
    "overlay": "14-overlay-light"
  },
  "tokenReplacements": {
    "color": {
      "01-primary-light": { "light": "#9CD5FF", "dark": "#6CC1FF", "usage": "Primary accent, lighter variant" },
      "02-primary": { "light": "#22A0FB", "dark": "#45B1FF", "usage": "Primary brand color, active states, links" },
      "03-primary-dark": { "light": "#C1E5FF", "dark": "#213D51", "usage": "Primary accent backgrounds" },
      "04-primary-darker": { "light": "#CCE7FB", "dark": "#2E5168", "usage": "Darker primary accent" },
      "05-surface-secondary": { "light": "#E9F6FF", "dark": "#2B2F3A", "usage": "Secondary surface color" },
      "06-text-primary": { "light": "#000000", "dark": "#FFFFFF", "usage": "Primary text color" },
      "07-text-secondary": { "light": "#707070", "dark": "#8B8B8B", "usage": "Secondary text, placeholders" },
      "08-text-tertiary": { "light": "#D5D5D5", "dark": "#414149", "usage": "Tertiary text, disabled, standard divider color" },
      "09-surface-tertiary": { "light": "#FCFAFA", "dark": "#2A2A30", "usage": "Tertiary surface" },
      "10-background": { "light": "#FFFFFF", "dark": "#1D1D21", "usage": "Primary background" },
      "11-error": { "light": "#EF4A68", "dark": "#BE424D", "usage": "Error states, destructive actions" },
      "12-important": { "light": "#FFCD4F", "dark": "#FFDC84", "usage": "Important states, caution" },
      "13-info": { "light": "#0D93F3", "dark": "#3DAEFF", "usage": "Information, links" },
      "14-overlay-light": { "light": "rgba(0, 0, 0, 0.04)", "dark": "rgba(255, 255, 255, 0.06)", "usage": "Light overlays, selection backgrounds, subtle divider color" },
      "15-overlay-primary": { "light": "rgba(76, 180, 255, 0.12)", "dark": "rgba(76, 180, 255, 0.12)", "usage": "Primary color overlays" },
      "16-overlay-subtle": { "light": "rgba(143, 208, 255, 0.08)", "dark": "rgba(75, 91, 103, 0.08)", "usage": "Subtle overlays" },
      "17-success-light": { "light": "#E8F5CE", "dark": "#E8F5CE", "usage": "Success backgrounds" },
      "18-success": { "light": "#7EBA02", "dark": "#7EBA02", "usage": "Success states" },
      "19-warning-alt": { "light": "#F7A501", "dark": "#F7A501", "usage": "Alternative warning" },
      "20-error-light": { "light": "#FEE9EB", "dark": "#461D21", "usage": "Error backgrounds" },
      "21-purple-light": { "light": "#E8E5FF", "dark": "#B4AEDC", "usage": "Purple accent light" },
      "22-purple": { "light": "#6450F9", "dark": "#7F6EFF", "usage": "Purple accent" },
      "23-pink-light": { "light": "#F6D4FF", "dark": "#F6D4FF", "usage": "Pink accent light" },
      "24-pink": { "light": "#BF3EE2", "dark": "#BF3EE2", "usage": "Pink accent" },
      "25-neutral": { "light": "#BDBDBD", "dark": "#727272", "usage": "Neutral gray" }
    }
  }
}
