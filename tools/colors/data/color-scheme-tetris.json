{
  "name": "Tetris",
  "target": "Cross-platform",
  "version": "1.0.1",
  "purpose": "Programming-friendly palette inspired by One Dark Pro. Built for engineers who prefer calm contrast, readable surfaces, and familiar syntax-theme accents.",
  "notes": [
    "Tetris uses One Dark Pro's dark-editor language as the anchor: charcoal surfaces, blue primary actions, purple/pink category accents, green success, yellow important states, and red errors.",
    "The light mode keeps the same hue relationships but lifts surfaces into a quiet editor-paper range so it still feels technical without becoming harsh.",
    "Accent colors are intentionally saturated enough for recognition, but muted enough for repeated UI use across Desktop, iOS, and Android."
  ],
  "semanticAliases": {
    "filoPrimary": "02-primary",
    "filoSecondary": "01-primary-light",
    "background": "10-background",
    "surface": "09-surface-tertiary",
    "textPrimary": "06-text-primary",
    "textSecondary": "07-text-secondary",
    "textTertiary": "08-text-tertiary",
    "error": "11-error",
    "warning": "12-important",
    "success": "18-success",
    "info": "13-info",
    "overlay": "14-overlay-light"
  },
  "tokenReplacements": {
    "color": {
      "01-primary-light": {
        "light": "#66DBA5",
        "dark": "#8FC7F2",
        "usage": "Primary accent, lighter variant"
      },
      "02-primary": {
        "light": "#43B983",
        "dark": "#61AFEF",
        "usage": "Primary brand color, active states, links"
      },
      "03-primary-dark": {
        "light": "#93E8C1",
        "dark": "#22384D",
        "usage": "Primary accent backgrounds"
      },
