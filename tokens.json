{
  "name": "Filo Design Tokens",
  "version": "2.0.0",
  "description": "Shared design tokens for all platforms (Desktop, iOS, Android). Source of truth for colors, typography, spacing, radius, and dividers.",

  "color": {
    "01-primary-light":    { "light": "#1F9EFA", "dark": "#6CC1FF", "usage": "Primary accent, lighter variant" },
    "02-primary":          { "light": "#22A0FB", "dark": "#45B1FF", "usage": "Primary brand color, active states, links" },
    "03-primary-dark":     { "light": "#4BACF5", "dark": "#213D51", "usage": "Primary accent backgrounds" },
    "04-primary-darker":   { "light": "#5ABEFF", "dark": "#2E5168", "usage": "Darker primary accent" },
    "05-surface-secondary":{ "light": "#E8EEF2", "dark": "#344352", "usage": "Secondary surface color" },
    "06-text-primary":     { "light": "#000000", "dark": "#FFFFFF", "usage": "Primary text color" },
    "07-text-secondary":   { "light": "#707070", "dark": "#8B8B8B", "usage": "Secondary text, placeholders" },
    "08-text-tertiary":    { "light": "#999999", "dark": "#414149", "usage": "Tertiary text, disabled, standard divider color" },
    "09-surface-tertiary": { "light": "#F5F5F5", "dark": "#2A2A30", "usage": "Tertiary surface" },
    "10-background":       { "light": "#FFFFFF", "dark": "#1D1D21", "usage": "Primary background" },
    "11-error":            { "light": "#E53935", "dark": "#BE424D", "usage": "Error states, destructive actions" },
    "12-warning":          { "light": "#FFB800", "dark": "#FFDC84", "usage": "Warning states, caution" },
    "13-info":             { "light": "#22A0FB", "dark": "#3DAEFF", "usage": "Information, links" },
    "14-overlay-light":    { "light": "rgba(0, 0, 0, 0.04)", "dark": "rgba(255, 255, 255, 0.06)", "usage": "Light overlays, selection backgrounds, subtle divider color" },
    "15-overlay-primary":  { "light": "rgba(34, 160, 251, 0.08)", "dark": "rgba(76, 180, 255, 0.12)", "usage": "Primary color overlays" },
    "16-overlay-subtle":   { "light": "rgba(0, 0, 0, 0.02)", "dark": "rgba(75, 91, 103, 0.08)", "usage": "Subtle overlays" },
    "17-success-light":    { "light": "#E8F5CE", "dark": "#9BB26C", "usage": "Success backgrounds" },
    "18-success":          { "light": "#7EBA02", "dark": "#7EBA02", "usage": "Success states" },
    "19-warning-alt":      { "light": "#F7A501", "dark": "#F7A501", "usage": "Alternative warning" },
    "20-error-light":      { "light": "#FFE5E7", "dark": "#461D21", "usage": "Error backgrounds" },
    "21-purple-light":     { "light": "#E8E6F5", "dark": "#B4AEDC", "usage": "Purple accent light" },
    "22-purple":           { "light": "#7F6EFF", "dark": "#7F6EFF", "usage": "Purple accent" },
    "23-pink-light":       { "light": "#FFF0F5", "dark": "#F6D4FF", "usage": "Pink accent light" },
    "24-pink":             { "light": "#BF3EE2", "dark": "#BF3EE2", "usage": "Pink accent" },
    "25-neutral":          { "light": "#9E9E9E", "dark": "#727272", "usage": "Neutral gray" }
  },

  "semanticAliases": {
    "filoPrimary":   "02-primary",
    "filoSecondary": "01-primary-light",
    "background":    "10-background",
    "surface":       "09-surface-tertiary",
    "textPrimary":   "06-text-primary",
    "textSecondary": "07-text-secondary",
    "textTertiary":  "08-text-tertiary",
    "error":         "11-error",
    "warning":       "12-warning",
    "success":       "18-success",
    "info":          "13-info",
    "overlay":       "14-overlay-light"
  },

  "glassEffect": {
    "light": { "background": "rgba(247, 247, 247, 0.85)", "border": "rgba(255, 255, 255, 0.5)", "blur": "20px" },
    "dark":  { "background": "rgba(40, 40, 40, 0.85)",    "border": "rgba(255, 255, 255, 0.1)", "blur": "20px" }
  },

  "typography": {
    "fonts": {
      "primary": "SF Pro",
      "platformFallbacks": {
        "apple": "SF Pro",
        "android": "Roboto",
        "windows": "Segoe UI"
      },
      "cssFallback": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, system-ui, sans-serif"
    },
    "weights": {
      "regular": 400,
      "medium": 510,
      "bold": 700
    },
    "styles": {
      "H1":     { "weight": 700, "size": 40, "lineHeight": 1.3,  "letterSpacing": 0.2,  "usage": "Main page titles, hero sections" },
      "H2":     { "weight": 700, "size": 32, "lineHeight": 1.3,  "letterSpacing": 0.2,  "usage": "Section headers" },
      "H3":     { "weight": 700, "size": 28, "lineHeight": 1.3,  "letterSpacing": 0.1,  "usage": "Sub-section headers" },
      "H4":     { "weight": 700, "size": 26, "lineHeight": 1.3,  "letterSpacing": 0,    "usage": "Card titles, modal headers" },
      "H5":     { "weight": 700, "size": 22, "lineHeight": 1.2,  "letterSpacing": 0,    "usage": "Small headers, labels" },
      "P1_B":   { "weight": 700, "size": 19, "lineHeight": 1.4,  "letterSpacing": -0.2, "usage": "Large body text bold" },
      "P1_M":   { "weight": 510, "size": 19, "lineHeight": 1.4,  "letterSpacing": -0.2, "usage": "Large body text medium" },
      "P1.1_B": { "weight": 700, "size": 17, "lineHeight": 1.4,  "letterSpacing": -0.2, "usage": "Body text bold" },
      "P1.1_R": { "weight": 400, "size": 17, "lineHeight": 1.4,  "letterSpacing": -0.2, "usage": "Body text regular" },
      "P2_B":   { "weight": 700, "size": 16, "lineHeight": 1.3,  "letterSpacing": -0.2, "usage": "Standard body bold" },
      "P2_M":   { "weight": 510, "size": 16, "lineHeight": 1.3,  "letterSpacing": -0.2, "usage": "Standard body medium" },
      "P2_R":   { "weight": 400, "size": 16, "lineHeight": 1.3,  "letterSpacing": -0.2, "usage": "Standard body regular" },
      "P3_B":   { "weight": 700, "size": 15, "lineHeight": 1.35, "letterSpacing": -0.2, "usage": "Small body bold" },
      "P3_M":   { "weight": 510, "size": 15, "lineHeight": 1.3,  "letterSpacing": -0.2, "usage": "Small body medium" },
      "P3_R":   { "weight": 400, "size": 15, "lineHeight": 1.35, "letterSpacing": -0.2, "usage": "Small body regular" },
      "P3.1_M": { "weight": 510, "size": 14, "lineHeight": 1.35, "letterSpacing": -0.2, "usage": "Extra small body medium" },
      "P4_B":   { "weight": 700, "size": 13, "lineHeight": 1.2,  "letterSpacing": 0,    "usage": "Caption bold" },
      "P4_R":   { "weight": 400, "size": 13, "lineHeight": 1.2,  "letterSpacing": 0,    "usage": "Caption regular" },
      "P5_B":   { "weight": 700, "size": 10, "lineHeight": 1.2,  "letterSpacing": 0,    "usage": "Micro text bold" },
      "P5_R":   { "weight": 400, "size": 10, "lineHeight": 1.2,  "letterSpacing": 0,    "usage": "Micro text regular" }
    }
  },

  "spacing": {
    "unit": "px",
    "scale": {
      "space-1": { "value": 4,  "usage": "Micro spacing — icon padding, tight gaps" },
      "space-2": { "value": 8,  "usage": "Small spacing — between related elements, button padding" },
      "space-3": { "value": 12, "usage": "Medium-small spacing — list item gaps, card padding" },
      "space-4": { "value": 16, "usage": "Medium spacing — section padding, standard gaps" },
      "space-5": { "value": 20, "usage": "Medium-large spacing — container padding, between sections" },
      "space-6": { "value": 30, "usage": "Large spacing — major section gaps" },
      "space-7": { "value": 40, "usage": "Extra large spacing — page margins, hero sections" }
    },
    "commonUseCases": {
      "iconPadding": 4,
      "buttonPaddingX": 16,
      "buttonPaddingY": 8,
      "cardPadding": 16,
      "listItemGap": 12,
      "sectionGap": 20,
      "pageMargin": 20,
      "modalPadding": 20,
      "headerPadding": 16,
      "inputPadding": 12
    }
  },

  "radius": {
    "unit": "px",
    "scale": {
      "radius-1":    { "value": 16,  "usage": "Small radius — buttons, inputs, small cards" },
      "radius-2":    { "value": 20,  "usage": "Medium radius — cards, modals, containers" },
      "radius-3":    { "value": 24,  "usage": "Large radius — large cards, sheets" },
      "radius-4":    { "value": 30,  "usage": "Extra large radius — feature cards, hero elements" },
      "radius-pill": { "value": 999, "usage": "Pill shape — single-line cells, tags, chips, tab bars" }
    },
    "rules": {
      "singleLineCell": "Always use pill (999) for single-line content cells",
      "multiLineCell": "Use radius-1 (16) or radius-2 (20) for multi-line cells",
      "nestedRadius": "Inner radius should be smaller than outer radius"
    }
  },

  "dividers": {
    "standard": {
      "colorToken": "08-text-tertiary",
      "height": "0.5px",
      "usage": "Between list items, sections, or content blocks"
    },
    "subtle": {
      "colorToken": "14-overlay-light",
      "height": "0.5px",
      "usage": "Frame edges when overlapping another frame for subtle depth separation"
    }
  }
}
